# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Multi-Agent Orchestrator"
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/orchestrator
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_in_production

# ─── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=

# ─── LLM settings ─────────────────────────────────────────────────────────────
# DEFAULT_MODEL used in production; TEST_MODEL used for fallback / local dev
DEFAULT_MODEL=claude-sonnet-4-6
TEST_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_S=30
LLM_MAX_RETRIES=3
LLM_FALLBACK_ENABLED=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list is NOT supported here — edit config.py ALLOWED_ORIGINS list
